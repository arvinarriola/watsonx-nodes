# ─── Application ────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ───────────────────────────────────
# For local Docker development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=watsonx_nodes

# For Supabase (Option B hosting) — replace DATABASE_URL with your Supabase connection string
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── JWT Auth ───────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ─── IBM Watson Assistant ────────────────────────
# API key from IBM Cloud → Watson Assistant → Service credentials
# Note: if the key shows as "ApiKey-xxxx", use the full string — the SDK strips the prefix.
WATSON_API_KEY=your_watson_api_key
# Instance URL from service credentials (region-specific)
WATSON_INSTANCE_URL=https://api.us-south.assistant.watson.cloud.ibm.com/instances/your-instance-id
# Assistant ID from Watson Assistant settings
WATSON_ASSISTANT_ID=your_assistant_id
# Environment ID — run: node backend/src/scripts/listWatsonEnvironments.js
# Use the "draft" environment for testing, "live" for production
WATSON_ENVIRONMENT_ID=your_environment_id

# ─── Slack ──────────────────────────────────────
# Per-subscriber webhook URLs are stored in the database.
# This is an optional default/test webhook.
SLACK_TEST_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# ─── Microsoft Teams ────────────────────────────
# Per-subscriber webhook URLs are stored in the database.
# This is an optional default/test webhook.
TEAMS_TEST_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com:443/workflows/...

# ─── Twilio (WhatsApp) ──────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Frontend ───────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api
